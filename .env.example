# ClawCraft - Environment Variables

# Minecraft Server
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=ClawCraft
MC_VERSION=1.20.4
MC_AUTH=offline

# LLM Provider (anthropic | openai | local)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# Discord (optional)
DISCORD_ENABLED=false
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=

# Agent Behavior
AGENT_NAME=ClawCraft
TICK_RATE=50
THINK_INTERVAL=10000
AUTONOMY_LEVEL=0.5

# Logging
LOG_LEVEL=info
